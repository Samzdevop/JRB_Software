// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String        @id @default(cuid())
  email               String        @unique
  googleId            String?       @unique
  password            String?
  fullName            String
  avatar              String?
  location            String?
  role                Role          @default(ADMIN)
  isDeleted           Boolean       @default(false)
  lastLogin           DateTime?
  verificationCode    String?
  verificationExpires DateTime?
  isVerified          Boolean       @default(false)
  isSuspended         Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  livestockAdded      Livestock[]   @relation("LivestockAddedBy")
  livestockUpdated    Livestock[]   @relation("LivestockUpdatedBy")
  vaccination         Vaccination[]
}

model Livestock {
  id                 String        @id @default(cuid())
  tagId              String        @unique
  type               String
  breed              String?
  birthDate          DateTime?
  healthStatus       HealthStatus
  weight             Float?
  gender             String
  livestockSource    String?
  livestockPurpose   String?
  addedBy            User          @relation("LivestockAddedBy", fields: [addedById], references: [id])
  addedById          String
  updatedBy          User?         @relation("LivestockUpdatedBy", fields: [updatedById], references: [id])
  updatedById        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  vaccinationRecords Vaccination[]
}

model Vaccination {
  id                String    @id @default(cuid())
  livestock         Livestock @relation(fields: [livestockId], references: [id])
  livestockId       String
  dateofVaccination DateTime
  vaccineType       String
  dosage            Float
  administeredBy    String
  nextDueDate       DateTime?
  recordedBy        User      @relation(fields: [recordedById], references: [id])
  recordedById      String
  createdAt         DateTime  @default(now())
}

modal SickRecord {
  id                String    @id @default(cuid())
  livestockId       String
}

enum HealthStatus {
  HEALTHY
  SICK
  IN_TREATMENT
  RECOVERING
  CRITICAL
}

enum InventoryAction {
  ADDED
  SOLD
  VACCINATED
  SICK
  TREATED
  MOVED
  DIED
  PURCHASED
}

enum Role {
  ADMIN
  FARM_KEEPER
  COWORKER
  VET
}
