// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String          @id @default(cuid())
  email               String?         @unique
  phone               String?         @unique
  googleId            String?         @unique
  password            String?
  fullName            String
  avatar              String?
  location            String?
  role                Role            @default(ADMIN)
  lastLogin           DateTime?
  verificationCode    String?
  verificationExpires DateTime?
  isVerified          Boolean         @default(false)
  isSuspended         Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  livestockAdded      Livestock[]     @relation("LivestockAddedBy")
  livestockUpdated    Livestock[]     @relation("LivestockUpdatedBy")
  vaccination         Vaccination[]
  Sickness            Sickness[]
  Treatment           Treatment[]
  OfftakeRecord       OfftakeRecord[]
}

model Livestock {
  id                 String          @id @default(cuid())
  tagId              String          @unique
  type               String
  breed              String?
  birthDate          DateTime?
  healthStatus       HealthStatus
  weight             Float?
  gender             String
  livestockSource    String?
  livestockPurpose   String?
  isSick             Boolean         @default(false)
  isTreatment        Boolean         @default(false)
  sickness           Sickness[]
  treatments         Treatment[]
  addedBy            User            @relation("LivestockAddedBy", fields: [addedById], references: [id])
  addedById          String
  updatedBy          User?           @relation("LivestockUpdatedBy", fields: [updatedById], references: [id])
  updatedById        String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  vaccinationRecords Vaccination[]
  OfftakeRecord      OfftakeRecord[]
}

model Vaccination {
  id                String    @id @default(cuid())
  livestock         Livestock @relation(fields: [livestockId], references: [id])
  livestockId       String
  dateofVaccination DateTime
  vaccineType       String
  dosage            Float
  administeredBy    String
  nextDueDate       DateTime?
  recordedBy        User      @relation(fields: [recordedById], references: [id])
  recordedById      String
  createdAt         DateTime  @default(now())
}

model Sickness {
  id                String      @id @default(cuid())
  livestock         Livestock   @relation(fields: [livestockId], references: [id])
  livestockId       String
  dateOfObservation DateTime
  observedSymptoms  String
  suspectedCause    String?
  notes             String?
  recordedBy        User        @relation(fields: [recordedById], references: [id])
  recordedById      String
  createdAt         DateTime    @default(now())
  treatments        Treatment[]
}

model Treatment {
  id              String    @id @default(cuid())
  sickness        Sickness? @relation(fields: [sicknessId], references: [id])
  sicknessId      String?
  livestock       Livestock @relation(fields: [livestockId], references: [id])
  livestockId     String
  dateOfTreatment DateTime
  treatmentType   String
  dosage          Float
  cause           String
  administeredBy  String
  nextDueDate     DateTime?
  recordedBy      User      @relation(fields: [recordedById], references: [id])
  recordedById    String
  createdAt       DateTime  @default(now())
}

model OfftakeRecord {
  id           String    @id @default(cuid())
  livestock    Livestock @relation(fields: [livestockId], references: [id])
  livestockId  String
  type         Offtake
  dateOfEvent  DateTime
  destination  String?
  price        Float?
  causeOfDeath String?
  notes        String?
  recordedBy   User      @relation(fields: [recordedById], references: [id])
  recordedById String
  createdAt    DateTime  @default(now())

  @@index([livestockId])
  @@index([type])
}

enum HealthStatus {
  HEALTHY
  SICK
  IN_TREATMENT
  RECOVERING
  CRITICAL
}

enum Offtake {
  SALE
  DEATH
  MISSING
}

enum Role {
  ADMIN
  FARM_KEEPER
  COWORKER
  VET
}
