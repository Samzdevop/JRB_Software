# For production (pointing to Render)
DATABASE_URL=your_production_database_url_here
PGSSLMODE=require
BASE_URL=https://your_production_base_url_here/
NODE_ENV="development"

# JWT Authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=1h

# CORS (Frontend URL)
CORS_ORIGIN=https://your_production_base_url_here/

# Google OAuth (if using Google Auth)
GOOGLE_CLIENT_ID=your google client id here
GOOGLE_CLIENT_SECRET=your google client secret here
GOOGLE_CALLBACK_URL=https://your_production_base_url_here/api/v1/auth/google/callback

# Email
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username_here
SMTP_PASSWORD=your_smtp_password_here
SMTP_SECURE=true
SMTP_SECURITTY_PROTOCOL=STARTTLS


# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_BUCKET_NAME=
# STORAGE_DRIVER=s3


